# ============================================
# Crescendo — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values.

# --- Application ---
APP_NAME=Crescendo
APP_ENV=development
DEBUG=true

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_USER=crescendo
POSTGRES_PASSWORD=crescendo_secret
POSTGRES_DB=crescendo_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=crescendo_analytics

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Spotify API ---
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback

# --- Genius API ---
GENIUS_ACCESS_TOKEN=your-genius-access-token

# --- Pinecone (Vector DB) ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=crescendo-embeddings

# --- AWS (Optional) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=crescendo-assets

# --- ML Pipeline ---
MODEL_PATH=./ml_pipeline/saved_models
MODEL_VERSION=v1.0.0
